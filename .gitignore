# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# conversas WhatsApp exportadas (dados pessoais de clientes — RGPD).
# Estão em public/ só para leitura local; NUNCA podem ir para o git,
# senão o Vercel serve-as publicamente.
/public/conversas whatsapp/

# typescript
*.tsbuildinfo
next-env.d.ts

# ficheiros de trabalho locais (nunca para o repo nem para o public/)
/_privado/

# permissões locais do Claude Code (por máquina; as duráveis vivem em .claude/settings.json)
.claude/settings.local.json
